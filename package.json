{
  "name": "fossil-scm",
  "displayName": "Fossil SCM",
  "description": "Fossil SCM Plugin",
  "repository": {
    "url": "https://github.com/darkmusic/fossil-vscode"
  },
  "version": "1.0.6",
  "publisher": "darkmusic",
  "license": "MIT",
  "engines": {
    "vscode": "^1.95.0"
  },
  "enabledApiProposals": [
    "timeline"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:**/.fslckout",
    "workspaceContains:**/_FOSSIL_"
  ],
  "main": "dist/extension.js",
  "icon": "resources/icons/icon.png",
  "contributes": {
    "commands": [
      {
        "command": "extension.fossilSCM",
        "title": "Fossil SCM",
        "icon": "$(refresh)"
      },
      {
        "command": "fossil.refresh",
        "title": "Refresh",
        "category": "Fossil",
        "icon": "$(refresh)"
      },
      {
        "command": "fossil.add",
        "title": "Add to Checkout",
        "category": "Fossil",
        "icon": "$(add)"
      },
      {
        "command": "fossil.resetAdd",
        "title": "Reset Add",
        "category": "Fossil",
        "icon": "$(remove)"
      },
      {
        "command": "fossil.revert",
        "title": "Revert",
        "category": "Fossil",
        "icon": "$(discard)"
      },
      {
        "command": "fossil.rm",
        "title": "Mark as Deleted",
        "category": "Fossil",
        "icon": "$(trash)"
      },
      {
        "command": "fossil.commit",
        "title": "Commit",
        "category": "Fossil",
        "icon": "$(check)"
      },
      {
        "command": "fossil.sync",
        "title": "Sync",
        "category": "Fossil",
        "icon": "$(sync)"
      },
      {
        "command": "fossil.startUi",
        "title": "Start Fossil UI",
        "category": "Fossil",
        "icon": "$(globe)"
      },
      {
        "command": "fossil.stopUi",
        "title": "Stop Fossil UI",
        "category": "Fossil",
        "icon": "$(debug-stop)"
      },
      {
        "command": "fossil.openMergeEditor",
        "title": "Open in Merge Editor",
        "category": "Fossil",
        "icon": "$(merge)"
      },
      {
        "command": "fossil.openChange",
        "title": "Open Fossil Change",
        "icon": "$(diff)"
      },
      {
        "command": "fossil.viewTimeline",
        "title": "View Timeline (Output)",
        "category": "Fossil"
      },
      {
        "command": "fossil.viewTimeline.explorer",
        "title": "View Timeline",
        "category": "Fossil"
      },
      {
        "command": "fossil.timeline.openDiff",
        "title": "Open Diff",
        "category": "Fossil",
        "icon": "$(compare-changes)"
      },
      {
        "command": "fossil.timeline.copyHash",
        "title": "Copy Check-in ID",
        "category": "Fossil"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "fossil.refresh",
          "when": "scmProvider == fossil",
          "group": "navigation@1"
        },
        {
          "command": "fossil.sync",
          "when": "scmProvider == fossil",
          "group": "navigation@2"
        },
        {
          "command": "fossil.commit",
          "when": "scmProvider == fossil && !fossil.commitInProgress",
          "group": "navigation@3"
        },
        {
          "command": "fossil.commit",
          "when": "scmProvider == fossil && fossil.commitInProgress",
          "group": "navigation@3",
          "icon": "$(loading~spin)"
        },
        {
          "command": "fossil.startUi",
          "when": "scmProvider == fossil && !fossil.uiRunning && !fossil.uiStarting",
          "group": "navigation@4"
        },
        {
          "command": "fossil.startUi",
          "when": "scmProvider == fossil && fossil.uiStarting",
          "group": "navigation@4",
          "icon": "$(loading~spin)"
        },
        {
          "command": "fossil.stopUi",
          "when": "scmProvider == fossil && fossil.uiRunning && !fossil.uiStarting",
          "group": "navigation@4"
        }
      ],
      "scm/resourceState/context": [
        {
          "command": "fossil.add",
          "when": "scmProvider == fossil && (scmResourceState == extra || scmResourceState == unmanage)",
          "group": "1_sync@1"
        },
        {
          "command": "fossil.resetAdd",
          "when": "scmProvider == fossil && scmResourceState == added",
          "group": "1_sync@2"
        },
        {
          "command": "fossil.rm",
          "when": "scmProvider == fossil && scmResourceState == missing",
          "group": "1_sync@2"
        },
        {
          "command": "fossil.revert",
          "when": "scmProvider == fossil && (scmResourceState == edited || scmResourceState == deleted || scmResourceState == added || scmResourceState == renamed || scmResourceState == conflict || scmResourceState == missing)",
          "group": "1_sync@3"
        },
        {
          "command": "fossil.openMergeEditor",
          "when": "scmProvider == fossil && scmResourceState == conflict",
          "group": "1_sync@4"
        },
        {
          "command": "fossil.viewTimeline",
          "when": "scmProvider == fossil && (scmResourceGroup == tracked || scmResourceGroup == unmanaged)",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "fossil.viewTimeline.explorer",
          "when": "fossil.hasCheckout && resourceScheme == file && explorerResourceIsFolder == false",
          "group": "4_timeline"
        }
      ],
      "timeline/item/context": [
        {
          "command": "fossil.timeline.openDiff",
          "when": "fossil.hasCheckout && timelineItem == fossilCommit && !listMultiSelection",
          "group": "1_actions@1"
        },
        {
          "command": "fossil.timeline.copyHash",
          "when": "fossil.hasCheckout && timelineItem == fossilCommit && !listMultiSelection",
          "group": "5_copy@1"
        }
      ],
      "commandPalette": [
        {
          "command": "fossil.refresh",
          "when": "fossil.hasCheckout"
        },
        {
          "command": "fossil.commit",
          "when": "fossil.hasCheckout"
        },
        {
          "command": "fossil.sync",
          "when": "fossil.hasCheckout"
        },
        {
          "command": "fossil.startUi",
          "when": "fossil.hasCheckout && !fossil.uiRunning && !fossil.uiStarting"
        },
        {
          "command": "fossil.stopUi",
          "when": "fossil.hasCheckout && fossil.uiRunning && !fossil.uiStarting"
        },
        {
          "command": "fossil.add",
          "when": "false"
        },
        {
          "command": "fossil.resetAdd",
          "when": "false"
        },
        {
          "command": "fossil.revert",
          "when": "false"
        },
        {
          "command": "fossil.rm",
          "when": "false"
        },
        {
          "command": "fossil.viewTimeline.explorer",
          "when": "fossil.hasCheckout && explorerViewletVisible && explorerResourceIsFolder == false"
        },
        {
          "command": "fossil.viewTimeline",
          "when": "fossil.hasCheckout && editorTextFocus && resourceScheme == file"
        },
        {
          "command": "fossil.timeline.openDiff",
          "when": "false"
        },
        {
          "command": "fossil.timeline.copyHash",
          "when": "false"
        },
        {
          "command": "fossil.openMergeEditor",
          "when": "fossil.hasCheckout && editorTextFocus && resourceScheme == file"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "Fossil-SCM Configuration",
      "properties": {
        "fossilScm.fossilExePath": {
          "type": "string",
          "default": "fossil",
          "description": "Path to fossil executable"
        },
        "fossilScm.crlfHandling": {
          "type": "string",
          "default": "accept",
          "enum": [
            "accept",
            "convert",
            "abort"
          ],
          "description": "How to handle files with CR/LF line endings when adding or committing.",
          "markdownEnumDescriptions": [
            "Accept CR/LF line endings as-is.",
            "Convert CR/LF line endings to LF.",
            "Abort the operation (fossil will exit with an error)."
          ]
        },
        "fossilScm.openDiffOnClick": {
          "type": "boolean",
          "default": true,
          "description": "Open the diff editor when clicking a file in the Changes view. When false, opens the working tree file; deleted files open the repository version instead."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./ && node esbuild.js",
    "check-types": "tsc --noEmit",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "vscode:prepublish": "npm run package",
    "package": "npm run check-types && node esbuild.js --production",
    "vsix": "vsce package --no-dependencies",
    "pretest": "npm run compile",
    "test": "vscode-test",
    "publish:marketplace": "vsce publish --packagePath ./*.vsix --skip-duplicate --allow-proposed-apis timeline"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.17.0",
    "@types/vscode": "^1.95.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.0",
    "esbuild": "^0.28.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.8.3"
  },
  "overrides": {
    "diff": "^8.0.3",
    "serialize-javascript": "^7.0.5"
  }
}
