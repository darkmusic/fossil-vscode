{
    "name": "fossil-scm",
    "displayName": "Fossil SCM",
    "description": "Fossil SCM Plugin",
    "repository": {
        "url": "https://github.com/darkmusic/fossil-vscode"
    },
    "version": "0.0.1",
    "publisher": "darkmusic",
    "license": "MIT",
    "engines": {
        "vscode": "^1.95.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onCommand:extension.fossilSCM"
    ],
    "main": "./out/extension",
    "contributes": {
        "commands": [
            {
                "command": "extension.fossilSCM",
                "title": "Fossil SCM"
            }
        ],
        "configuration": {
            "type": "object",
            "title": "Fossil-SCM Configuration",
            "properties": {
                "fossilScm.fossilExePath": {
                    "type": "string",
                    "default": "fossil",
                    "description": "Path to fossil executable"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile",
        "test": "vscode-test"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "^20.17.0",
        "@types/vscode": "^1.95.0",
        "@vscode/test-cli": "^0.0.12",
        "@vscode/test-electron": "^2.5.2",
        "typescript": "^5.8.3"
    },
    "overrides": {
        "diff": "^8.0.3",
        "serialize-javascript": "^7.0.5"
    }
}
