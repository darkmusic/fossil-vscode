{
    "name": "fossil-scm",
    "displayName": "Fossil SCM",
    "description": "Fossil SCM Plugin",
    "repository": {
        "url": "https://github.com/darkmusic/fossil-vscode"
    },
    "version": "0.0.1",
    "publisher": "darkmusic",
    "license": "MIT",
    "engines": {
        "vscode": "^1.95.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "workspaceContains:**/.fslckout",
        "workspaceContains:**/_FOSSIL_"
    ],
    "main": "./out/extension",
    "contributes": {
        "commands": [
            {
                "command": "extension.fossilSCM",
                "title": "Fossil SCM"
            },
            {
                "command": "fossil.openChange",
                "title": "Open Fossil Change",
                "icon": "$(diff)"
            }
        ],
        "configuration": {
            "type": "object",
            "title": "Fossil-SCM Configuration",
            "properties": {
                "fossilScm.fossilExePath": {
                    "type": "string",
                    "default": "fossil",
                    "description": "Path to fossil executable"
                },
                "fossilScm.openDiffOnClick": {
                    "type": "boolean",
                    "default": true,
                    "description": "Open the diff editor when clicking a file in the Changes view. When false, opens the working tree file; deleted files open the repository version instead."
                }
            }
        }
    },
    "scripts": {
        "compile": "tsc -p ./",
        "check-types": "tsc --noEmit",
        "watch": "npm-run-all -p watch:*",
        "watch:esbuild": "node esbuild.js --watch",
        "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
        "vscode:prepublish": "npm run package",
        "package": "npm run check-types && node esbuild.js --production",
        "pretest": "npm run compile",
        "test": "vscode-test"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "^20.17.0",
        "@types/vscode": "^1.95.0",
        "@vscode/test-cli": "^0.0.12",
        "@vscode/test-electron": "^2.5.2",
        "esbuild": "^0.28.0",
        "npm-run-all": "^4.1.5",
        "typescript": "^5.8.3"
    },
    "overrides": {
        "diff": "^8.0.3",
        "serialize-javascript": "^7.0.5"
    }
}
